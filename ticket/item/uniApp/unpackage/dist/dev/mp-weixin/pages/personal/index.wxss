.top-plane {
  position: relative;
  height: 472rpx;
}
.top-plane .info-plane {
  padding-top: 42rpx;
  padding-left: 36rpx;
  display: flex;
  width: 714rpx;
  height: 306rpx;
  background: linear-gradient(270deg, #2B9EFB 0%, #1779FE 100%);
  opacity: 1;
}
.top-plane .info-plane view.portrait {
  width: 130rpx;
  height: 130rpx;
  border: 10rpx solid #51B5FE;
  border-radius: 50%;
  overflow: hidden;
}
.top-plane .info-plane view.portrait image {
  width: 100%;
  height: 100%;
}
.top-plane .info-plane view.u-info {
  margin-left: 30rpx;
  margin-top: 8rpx;
}
.top-plane .info-plane view.u-info text.u-nickName {
  font-size: 44rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 58rpx;
  color: #FFFFFF;
  opacity: 1;
}
.top-plane .info-plane view.u-info view.u-sy {
  margin-top: 12rpx;
}
.top-plane .info-plane view.u-info view.u-sy text.u-sy-lable {
  font-size: 32rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 42rpx;
  color: #FFFFFF;
  opacity: 1;
}
.top-plane .info-plane view.u-info view.u-sy text.u-sy-txt {
  margin-left: 20rpx;
  font-size: 24rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 32rpx;
  color: #FFFFFF;
  opacity: 0.7;
}
.top-plane .top-tab-plane {
  position: absolute;
  margin: 0 30rpx;
  width: 690rpx;
  height: 250rpx;
  background: #FFFFFF;
  box-shadow: 0 6rpx 12rpx rgba(0, 0, 0, 0.15);
  opacity: 1;
  border-radius: 20rpx;
  bottom: 0;
  overflow: hidden;
}
.top-plane .top-tab-plane text.title {
  display: block;
  margin-top: 26rpx;
  margin-left: 34rpx;
  font-size: 36rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 48rpx;
  color: #333333;
  opacity: 1;
}
.top-plane .top-tab-plane .tab-list {
  display: flex;
  justify-content: space-between;
}
.top-plane .top-tab-plane .tab-list .tab-item {
  justify-content: center;
  align-items: center;
  display: flex;
  width: 200rpx;
  height: 165rpx;
}
.top-plane .top-tab-plane .tab-list .tab-item view.item-plane {
  align-items: center;
  justify-content: center;
}
.top-plane .top-tab-plane .tab-list .tab-item view.item-plane view.item-icon {
  width: 64rpx;
  height: 64rpx;
}
.top-plane .top-tab-plane .tab-list .tab-item view.item-plane view.item-icon image {
  width: 100%;
  height: 100%;
}
.top-plane .top-tab-plane .tab-list .tab-item text {
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 38rpx;
  color: #333333;
  opacity: 1;
}
.handle-list-plane {
  background-color: #FFFFFF;
  margin-top: 30rpx;
}
.handle-list-plane view.list-item {
  display: flex;
  align-items: center;
  padding-left: 58rpx;
  padding-right: 48rpx;
  width: 644rpx;
  height: 100rpx;
  position: relative;
  border-bottom: 2rpx solid #F7F7F7;
}
.handle-list-plane view.list-item view.icon {
  width: 46rpx;
  height: 46rpx;
}
.handle-list-plane view.list-item view.icon image {
  width: 100%;
  height: 100%;
}
.handle-list-plane view.list-item text.title {
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 38rpx;
  color: #111111;
  opacity: 1;
  text-indent: 24rpx;
}
.handle-list-plane view.list-item::before {
  width: 36rpx;
  height: 36rpx;
  display: block;
  content: '';
  background: url(data:image/png;base64,) no-repeat;
  background-size: contain;
  position: absolute;
  right: 48rpx;
  top: 36rpx;
}
.handle-list-plane view.list-item:last-child {
  border-bottom: 0;
}
.handle-list-plane:first-child {
  margin-top: 0;
}

