.body {
  width: 750rpx;
  height: 100%;
  background-color: #F6F6F6;
}
.tabs {
  width: 750rpx;
  background-color: #FFFFFF;
}
.tabs .van-ellipsis {
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 72rpx;
  color: #333333;
  opacity: 1;
}
.tabs .van-tabs__line {
  height: 6rpx;
  background: #0087F6;
  opacity: 1;
  border-radius: 10rpx;
}
.tabs .van-tabs__nav {
  height: 78rpx;
}
.tabs view.list-plane {
  padding-top: 14rpx;
}
.tabs view.list-plane view.data-plane {
  margin-top: 50rpx;
  position: relative;
  display: flex;
}
.tabs view.list-plane view.data-plane view.image-plane {
  width: 160rpx;
  height: 160rpx;
}
.tabs view.list-plane view.data-plane view.image-plane image {
  width: 100%;
  height: 100%;
}
.tabs view.list-plane view.data-plane view.data-content-plane {
  margin-left: 20rpx;
}
.tabs view.list-plane view.data-plane view.data-content-plane text {
  display: block;
  font-family: Microsoft YaHei;
  font-weight: 400;
}
.tabs view.list-plane view.data-plane view.data-content-plane text.title {
  font-size: 32rpx;
  line-height: 44rpx;
  color: #333333;
  opacity: 1;
  height: 44rpx;
  overflow: hidden;
}
.tabs view.list-plane view.data-plane view.data-content-plane text.state {
  margin-top: 24rpx;
  width: 124rpx;
  height: 50rpx;
  background: #0087F6;
  opacity: 1;
  border-radius: 16rpx 16rpx 16rpx 0rpx;
  text-align: center;
  font-size: 32rpx;
  line-height: 50rpx;
  color: #FFFFFF;
  opacity: 1;
}
.tabs view.list-plane view.data-plane view.data-content-plane text.discontinued {
  background: #7A7A7A;
}
.tabs view.list-plane view.data-plane view.data-content-plane text.moreTicket {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 32rpx;
  color: #707070;
  opacity: 1;
}
.tabs view.list-plane view.data-plane view.price_view {
  position: absolute;
  right: 0;
  bottom: 0;
  font-size: 40rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 52rpx;
  color: #FF6E00;
  opacity: 1;
}
.tabs view.list-plane view.data-plane view.price_view text.unit {
  font-size: 28rpx;
}

