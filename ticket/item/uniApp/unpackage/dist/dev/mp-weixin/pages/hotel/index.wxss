.body {
  background-color: #EEF2F6;
}
.top_swiper swiper {
  width: 750rpx;
  height: 380rpx;
}
.top_swiper swiper image {
  width: 100%;
  height: 100%;
}
.query-plane {
  width: 690rpx;
  padding: 38rpx 30rpx 40rpx;
  background-color: #FFFFFF;
}
.query-plane text.title {
  display: block;
  text-align: center;
  font-size: 40rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 52rpx;
  color: #333333;
  opacity: 1;
}
.query-plane view.form-plane {
  overflow: hidden;
  margin-top: 2rpx;
}
.query-plane view.form-plane view.form-item {
  width: 686rpx;
  height: 80rpx;
  border: 2rpx solid #0087F6;
  opacity: 1;
  border-radius: 10rpx;
  display: flex;
  margin-top: 32rpx;
}
.query-plane view.form-plane view.form-item image {
  width: 35rpx;
  height: 80rpx;
  margin: 0 22rpx 0 24rpx;
}
.query-plane view.form-plane view.form-item input {
  height: 80rpx;
  width: 100%;
}
.query-plane view.form-plane view.form-item .iplaceholder-class {
  font-size: 32rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 42rpx;
  color: #888888;
  opacity: 1;
}
.query-plane view.form-plane view.stepper-view {
  margin-top: 44rpx;
  width: 636rpx;
  padding: 0 27rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.query-plane view.form-plane view.stepper-view view.stepper-plane text.label {
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 38rpx;
  color: #333333;
  opacity: 1;
}
.query-plane view.form-plane view.stepper-view view.stepper-plane view.stepper-comp {
  margin-left: 32rpx;
  display: flex;
  margin-top: 26rpx;
}
.query-plane view.form-plane view.stepper-view view.stepper-plane view.stepper-comp input {
  width: 102rpx;
  height: 70rpx;
  text-align: center;
  font-size: 52rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 70rpx;
  color: #0087F6;
  opacity: 1;
}
.query-plane view.form-plane view.stepper-view view.stepper-plane view.stepper-comp view.icon {
  width: 40rpx;
  height: 70rpx;
  background-size: 40rpx;
  background-repeat: no-repeat;
  background-position: center;
}
.query-plane view.form-plane view.stepper-view view.stepper-plane view.stepper-comp view.subtract {
  background-image: url(data:image/png;base64,);
}
.query-plane view.form-plane view.stepper-view view.stepper-plane view.stepper-comp view.add {
  background-image: url(data:image/png;base64,);
}
.query-plane view.form-plane view.form-button button {
  margin-top: 60rpx;
  height: 90rpx;
  background: #FF6E00;
  opacity: 1;
  border-radius: 10rpx;
  font-size: 36rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 90rpx;
  color: #FFFFFF;
  opacity: 1;
}
.recommend {
  margin-top: 24rpx;
  width: 690rpx;
  background-color: #FFFFFF;
  padding: 40rpx 30rpx 24rpx;
}
.recommend text.title {
  font-size: 40rpx;
  color: #333333;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 52rpx;
}
.recommend view.item {
  margin-top: 30rpx;
}
.recommend view.item view.image-bg {
  margin-bottom: 18rpx;
  width: 690rpx;
  height: 300rpx;
  display: block;
}
.recommend view.item view.image-bg image {
  width: 100%;
  height: 100%;
}
.recommend view.item view.content {
  display: block;
}
.recommend view.item view.content text.title {
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 38rpx;
  color: #333333;
}
.hote-list-popup-view {
  width: 750rpx;
  border-radius: 30rpx 30rpx 0 0;
  background-color: #EEF2F6;
}
.hote-list-popup-view text.title {
  background-color: #FFFFFF;
  display: block;
  height: 80rpx;
  text-align: center;
  color: #333333;
  font-family: Microsoft YaHei;
  font-weight: bold;
  font-size: 32rpx;
  line-height: 80rpx;
  border-bottom: 1rpx solid #F7F7F7;
}
.hote-list-popup-view view.list-item {
  background-color: #FFFFFF;
}
.hote-list-popup-view view.list-item view.item {
  height: 100rpx;
  border-bottom: 1rpx solid #E5E5E5;
}
.hote-list-popup-view view.list-item view.item text {
  display: block;
  text-align: center;
  color: #333333;
  font-family: Microsoft YaHei;
  font-weight: 400;
  font-size: 28rpx;
  line-height: 100rpx;
}
.hote-list-popup-view view.list-item view.item:last-child {
  border-bottom: 0;
}
.hote-list-popup-view view.handle {
  background-color: #FFFFFF;
  margin-top: 10rpx;
  padding-bottom: 80rpx;
}
.hote-list-popup-view view.handle text {
  display: block;
  color: #333333;
  font-family: Microsoft YaHei;
  font-weight: 400;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
}
.picker-popup-view {
  width: 750rpx;
  border-radius: 30rpx 30rpx 0 0;
  background-color: #fff;
  overflow: hidden;
}

