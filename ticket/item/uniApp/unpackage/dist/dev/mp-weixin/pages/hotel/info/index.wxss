.top_swiper swiper {
  width: 750rpx;
  height: 380rpx;
}
.top_swiper swiper image {
  width: 100%;
  height: 100%;
}
.main {
  width: 690rpx;
  padding: 0 30rpx;
}
.main view.abstract-plane {
  padding-top: 26rpx;
  padding-bottom: 22rpx;
}
.main view.abstract-plane text.title {
  font-size: 32rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 42rpx;
  color: #333333;
  opacity: 1;
  display: block;
}
.main view.abstract-plane text.abstract {
  height: 120rpx;
  display: block;
  margin-top: 22rpx;
  font-size: 24rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 32rpx;
  color: #333333;
  opacity: 1;
}
.main view.bar {
  width: 690rpx;
  height: 38rpx;
  background: #E9F9FF;
  opacity: 1;
  border-radius: 10rpx;
  padding: 18rpx 0 25rpx;
}
.main view.bar view.data-plane {
  float: left;
  margin-left: 20rpx;
}
.main view.bar view.data-plane text.date-z {
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 38rpx;
  color: #333333;
  opacity: 1;
  margin-left: 20rpx;
}
.main view.bar view.data-plane text.date-i {
  font-size: 24rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 32rpx;
  color: #555555;
  opacity: 1;
  margin-left: 20rpx;
}
.main view.bar view.data-plane text.date-c {
  height: 36rpx;
  padding: 0 20rpx;
  border: 2rpx solid #D1D1D1;
  opacity: 1;
  border-radius: 60rpx;
  margin-left: 20rpx;
  font-size: 20rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 28rpx;
  color: #555555;
  opacity: 1;
}
.main view.list-plane {
  margin-bottom: 50rpx;
}
.main view.list-plane view.data-plane {
  height: 140rpx;
  padding: 26rpx 0 24rpx;
  border-bottom: 2px solid #E5E5E5;
  display: flex;
}
.main view.list-plane view.data-plane image {
  width: 196rpx;
  height: 140rpx;
}
.main view.list-plane view.data-plane view.content {
  width: 372rpx;
  margin-left: 12rpx;
}
.main view.list-plane view.data-plane view.content text {
  margin-bottom: 10rpx;
  display: block;
}
.main view.list-plane view.data-plane view.content text.title {
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 32rpx;
  color: #333333;
  opacity: 1;
}
.main view.list-plane view.data-plane view.content text.tips {
  font-size: 24rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 28rpx;
  opacity: 1;
}
.main view.list-plane view.data-plane view.handle {
  width: 110rpx;
}
.main view.list-plane view.data-plane view.handle view.price_view {
  float: right;
  font-size: 40rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 52rpx;
  color: #FF6E00;
  opacity: 1;
  margin-top: 26rpx;
}
.main view.list-plane view.data-plane view.handle view.price_view text.unit {
  font-size: 28rpx;
}
.main view.list-plane view.data-plane view.handle button {
  margin-top: 6rpx;
  width: 110rpx;
  height: 56rpx;
  background: #0087F6;
  opacity: 1;
  border-radius: 10rpx;
  padding: 0;
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 56rpx;
  color: #FFFFFF;
  opacity: 1;
}
.main view.list-plane view.data-plane:last-child {
  border: 0;
}
.popup-view view.popup-top-plane {
  width: 750rpx;
  height: 68rpx;
  background: #BEE2FF;
  opacity: 1;
  border-top: 6rpx solid #0087F6;
  position: relative;
}
.popup-view view.popup-top-plane text.title {
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 68rpx;
  color: #333333;
  opacity: 1;
  text-align: center;
  display: block;
}
.popup-view view.popup-top-plane image.close {
  width: 22rpx;
  height: 22rpx;
  position: absolute;
  right: 24rpx;
  top: 20rpx;
}
.popup-view view.popup-top-body {
  width: 690rpx;
  padding: 34rpx 30rpx 38rpx;
}
.popup-view view.popup-top-body view.top-plane {
  display: flex;
  justify-content: space-between;
}
.popup-view view.popup-top-body view.top-plane view.top-plane-left view.top-plane-left-t text.title {
  font-size: 32rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 42rpx;
  color: #555555;
  opacity: 1;
  margin-right: 26rpx;
}
.popup-view view.popup-top-body view.top-plane view.top-plane-left view.top-plane-left-t text.txt {
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 38rpx;
  color: #555555;
  opacity: 1;
  margin-right: 32rpx;
}
.popup-view view.popup-top-body view.top-plane view.top-plane-left view.top-plane-left-b {
  margin-top: 24rpx;
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 38rpx;
  color: #555555;
  opacity: 1;
}
.popup-view view.popup-top-body view.top-plane view.top-plane-right {
  margin-top: 6rpx;
}
.popup-view view.popup-top-body view.top-plane view.top-plane-right view.price_view {
  font-size: 40rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 52rpx;
  color: #FF6E00;
  opacity: 1;
}
.popup-view view.popup-top-body view.top-plane view.top-plane-right view.price_view text.unit {
  font-size: 28rpx;
}
.popup-view view.popup-top-body view.describe-plane {
  margin-top: 54rpx;
  padding-bottom: 20rpx;
}
.popup-view view.popup-top-body view.describe-plane text.title {
  font-size: 32rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 42rpx;
  color: #555555;
  opacity: 1;
}
.popup-view view.popup-top-body view.describe-plane view.content {
  margin-top: 24rpx;
  max-height: 800rpx;
  overflow: hidden;
  overflow-y: auto;
}
.popup-view view.popup-top-body view.describe-plane view.content text {
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 38rpx;
  color: #555555;
  opacity: 1;
  display: block;
}
.popup-view view.popup-top-body view.handle-plane {
  margin-top: 20rpx;
  margin-bottom: 38rpx;
}
.popup-view view.popup-top-body view.handle-plane button {
  width: 690rpx;
  height: 80rpx;
  background: #0087F6;
  opacity: 1;
  border-radius: 6px;
  font-size: 32rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 80rpx;
  color: #FFFFFF;
  opacity: 1;
  text-align: center;
}
._txt_green {
  color: #009A3D;
}
._txt_grey {
  color: #555555;
}

