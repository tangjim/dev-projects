<view class="body"><view class="top_swiper"><block wx:if="{{data.cover_display}}"><swiper indicator-dots="{{true}}" circular="{{true}}" autoplay="{{true}}"><block wx:for="{{data.cover_display}}" wx:for-item="img" wx:for-index="index" wx:key="index"><swiper-item><image src="{{img}}"></image></swiper-item></block></swiper></block></view><view class="main"><view class="title-plane"><block wx:if="{{data.name}}"><text class="title">{{data.name}}</text></block><text class="tips" space="emsp">{{getAttribute}}</text></view></view><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block wx:if="{{data.content}}"><view class="matters-plane"><text class="title">{{item.$orig.title}}</text><view class="content"><rich-text nodes="{{item.m0}}"></rich-text></view></view></block></block><view class="handle-plane"><view class="price-plane"></view><view class="handle-button"><button data-event-opts="{{[['tap',[['onBuy',['$event']]]]]}}" bindtap="__e">立即订购</button></view></view></view>