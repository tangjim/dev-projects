.body {
  position: relative;
}
.top-plane {
  width: 690rpx;
  height: 282rpx;
  background: linear-gradient(135deg, #C7E6FF 0%, #78C2FF 100%);
  opacity: 1;
  border-radius: 10rpx;
  margin: 40rpx 30rpx 36rpx;
  padding-top: 30rpx;
  position: relative;
}
.top-plane view.txt-plane text {
  font-family: Microsoft YaHei;
  margin-bottom: 10rpx;
  display: block;
  margin-left: 26rpx;
  font-size: 28rpx;
  line-height: 38rpx;
  opacity: 1;
}
.top-plane view.txt-plane text.txt1 {
  font-size: 32rpx;
  line-height: 42rpx;
  color: #333333;
  opacity: 1;
}
.top-plane view.price_view {
  position: absolute;
  right: 32rpx;
  bottom: 22rpx;
  font-size: 40rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 52rpx;
  color: #FF6E00;
  opacity: 1;
}
.top-plane view.price_view text.unit {
  font-size: 28rpx;
}
.form-plane text.title {
  font-size: 40rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 52rpx;
  color: #333333;
  opacity: 1;
  display: block;
  text-align: center;
  margin-bottom: 14rpx;
}
.form-plane view.form-handle-plane view.form-group {
  height: 80rpx;
  width: 690rpx;
  margin: 0 30rpx;
  border-bottom: 1px solid #E7ECED;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.form-plane view.form-handle-plane view.form-group text.label {
  width: 202rpx;
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 38rpx;
  color: #333333;
  opacity: 1;
}
.form-plane view.form-handle-plane view.form-group input {
  width: 100%;
}
.form-plane view.form-handle-plane view.form-group .iplaceholder-class {
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 38rpx;
  color: #C5D0D5;
  opacity: 1;
}
.handle-plane {
  position: fixed;
  bottom: 0;
  height: 88rpx;
  width: 690rpx;
  padding: 0 30rpx;
  margin-bottom: 34rpx;
  display: flex;
  justify-content: space-between;
}
.handle-plane view.price-plane text.lable {
  margin-top: 26rpx;
  font-size: 24rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 32rpx;
  color: #555555;
  opacity: 1;
  float: left;
}
.handle-plane view.price-plane view.price_view {
  float: left;
  margin-left: 20rpx;
  margin-top: 16rpx;
  font-size: 40rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 52rpx;
  color: #FF6E00;
  opacity: 1;
}
.handle-plane view.price-plane view.price_view text.unit {
  font-size: 28rpx;
}
.handle-plane button {
  width: 160rpx;
  height: 50rpx;
  background: #0087F6;
  opacity: 1;
  margin-top: 20rpx;
  border-radius: 6rpx;
  padding: 0;
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 50rpx;
  color: #FFFFFF;
  opacity: 1;
}
.bold {
  font-weight: bold;
}
.txt_c_333 {
  color: #333333;
}
.txt_c_555 {
  color: #555555;
}

