.body {
  background-color: #EEF2F6;
}
.top_swiper swiper {
  width: 750rpx;
  height: 380rpx;
}
.top_swiper swiper image {
  width: 100%;
  height: 100%;
}
.main {
  width: 690rpx;
  padding: 0 30rpx;
  background-color: #FFFFFF;
}
.main view.title-plane {
  padding: 26rpx 0 32rpx;
}
.main view.title-plane text.title {
  font-size: 32rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 42rpx;
  color: #333333;
  opacity: 1;
  display: block;
}
.main view.title-plane text.tips {
  margin-top: 16rpx;
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 38rpx;
  color: #0087F6;
  opacity: 1;
  display: block;
}
.main view.explain-main {
  border-top: 2px solid #E7ECED;
  padding: 30rpx 0;
}
.main view.explain-main text.title {
  font-size: 24rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 32rpx;
  color: #555555;
  opacity: 1;
  margin-bottom: 14rpx;
}
.main view.explain-main view.explain-plane {
  margin-top: 20rpx;
  display: flex;
}
.main view.explain-main view.explain-plane text {
  font-size: 24rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 32rpx;
  color: #555555;
  opacity: 1;
  display: block;
  width: 100%;
}
.main view.explain-main view.explain-plane text.label {
  width: 158rpx;
  display: block;
}
.matters-plane {
  width: 690rpx;
  margin-top: 24rpx;
  background-color: #FFFFFF;
  padding: 34rpx 30rpx 30rpx;
}
.matters-plane text.title {
  font-size: 24rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 32rpx;
  color: #555555;
  opacity: 1;
  margin-bottom: 34rpx;
  display: block;
}
.matters-plane view.content {
  font-size: 24rpx;
  font-family: Microsoft YaHei;
  font-weight: 400;
  line-height: 32rpx;
  color: #555555;
  opacity: 1;
}
.handle-plane {
  width: 690rpx;
  height: 88rpx;
  margin-top: 24rpx;
  background-color: #FFFFFF;
  padding: 0 30rpx;
  display: flex;
  justify-content: space-between;
}
.handle-plane view.price-plane text.lable {
  margin-top: 26rpx;
  font-size: 24rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 32rpx;
  color: #555555;
  opacity: 1;
  float: left;
}
.handle-plane view.price-plane view.price_view {
  float: left;
  margin-left: 20rpx;
  margin-top: 16rpx;
  font-size: 40rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 52rpx;
  color: #FF6E00;
  opacity: 1;
}
.handle-plane view.price-plane view.price_view text.unit {
  font-size: 28rpx;
}
.handle-plane button {
  width: 160rpx;
  height: 50rpx;
  background: #0087F6;
  opacity: 1;
  margin-top: 20rpx;
  border-radius: 6rpx;
  padding: 0;
  font-size: 28rpx;
  font-family: Microsoft YaHei;
  font-weight: bold;
  line-height: 50rpx;
  color: #FFFFFF;
  opacity: 1;
}

