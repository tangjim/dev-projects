function arrayFindById(arr, val, fieldName="id") {
  var o = {};
  // console.log(arr, val);
  if (arr) {
    for (var i=0; i<arr.length; i++) {
      // console.log(arr[i][fieldName] +"---"+val);
      if (arr[i][fieldName] === val) {
        o = arr[i];
        break;
      }
    }
  }
  return o;
}
function arrayIndexById(arr, val, fieldName="id") {
  var index = 0;
  // console.log(val);
  if (arr) {
    for (var i=0; i<arr.length; i++) {
      if (arr[i][fieldName] === val) {
        index = i;
        break;
      }
    }
  }
  return index;
}

module.exports = {
  arrayFindById: arrayFindById,
  arrayIndexById: arrayIndexById
}