.panel-item {
  display: flex;
  flex-direction: column;
  width: 676rpx;
  border: 2rpx solid #EEEEEE;
  border-radius: 10rpx 10rpx 10rpx 10rpx;
  margin-bottom: 19rpx;
  padding-bottom: 19rpx;
}

.panel-item .panel-item-title {
  display: flex;
  flex-direction: row;
}

.panel-item .panel-item-title .panel-item-title-text {
  background: #1F61FF;
  box-shadow: 0rpx 8rpx 15rpx 0rpx rgba(0, 0, 0, 0.25);
  border-radius: 10rpx 0rpx 10rpx 0rpx;
  font-family: Source Han Sans, Source Han Sans;
  font-weight: 400;
  font-size: 24rpx;
  color: #FFFFFF;
  line-height: 61rpx;
  text-align: center;
  font-style: normal;
  text-transform: none;
  padding: 0 19rpx;
}

.panel-item .panel-item-content {
  padding: 19rpx 0;
}

.panel-item .panel-item-content .panel-item-content-list {
  border-bottom: 2rpx dashed #E2E2E2;
  padding: 9.5rpx 19rpx;
  font-family: Source Han Sans, Source Han Sans;
  font-size: 24rpx;
  line-height: 48rpx;
  color: #3D3D3D;
  display: flex;
  flex-direction: row;
  gap: 9.5rpx;
  align-items: center;
  display: flex;
}

.panel-item .panel-item-content .panel-item-content-list .panel-item-content-from {
  display: flex;
  flex-direction: row;
  gap: 9.5rpx;
}

.panel-item .panel-item-content .info {
  font-family: Source Han Sans, Source Han Sans;
  font-weight: 400;
  font-size: 24rpx;
  color: #FF5800;
  line-height: 24rpx;
  text-indent: 19rpx;
  font-style: normal;
  text-transform: none;
  margin: 10rpx 0;
}

.panel-item .panel-item-handle {
  display: flex;
  flex-direction: row;
  gap: 19rpx;
  padding: 0 19rpx;
}