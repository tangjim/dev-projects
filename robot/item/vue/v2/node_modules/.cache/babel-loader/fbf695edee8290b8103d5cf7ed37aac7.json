AAA,OAAO,CAACS,OAAR,CAAgBH,GAAhB;AACH;AACJ,OARD;AASH,KAXI;AAYLI,IAAAA,QAZK,oBAYIN,OAZJ,EAYaJ,OAZb,EAYsB;AACvBR,MAAAA,mBAAmB,CAACQ,OAAO,CAACW,QAAT,CAAnB,CAAsCN,IAAtC,CAA2C,UAAAC,GAAG,EAAI;AAC9C;AACA,YAAIA,GAAG,CAACC,IAAJ,KAAa,IAAjB,EAAuB;AACnBH,UAAAA,OAAO,CAACI,MAAR,CAAelB,QAAf,EAAyB;AAACM,YAAAA,IAAI,EAAEU,GAAG,CAACJ,IAAJ,CAASN,IAAT,IAAiB;AAAxB,WAAzB;AACH;;AACD,YAAII,OAAO,CAACS,OAAZ,EAAqB;AACjBT,UAAAA,OAAO,CAACS,OAAR,CAAgBH,GAAhB;AACH;AACJ,OARD;AASH,KAtBI;AAuBLR,IAAAA,GAvBK,eAuBDM,OAvBC,EAuBQJ,OAvBR,EAuBiB;AAClBP,MAAAA,YAAY,CAACO,OAAO,CAACW,QAAT,CAAZ,CAA+BN,IAA/B,CAAoC,UAAAC,GAAG,EAAI;AACvC,YAAIA,GAAG,CAACC,IAAJ,KAAa,IAAjB,EAAuB;AACnBH,UAAAA,OAAO,CAACI,MAAR,CAAe,SAAf,EAA0B;AAACN,YAAAA,IAAI,EAAEI,GAAG,CAACJ;AAAX,WAA1B;AACH;;AACD,YAAIF,OAAO,CAACS,OAAZ,EAAqB;AACjBT,UAAAA,OAAO,CAACS,OAAR,CAAgBH,GAAhB;AACH;AACJ,OAPD;AAQH;AAhCI,GAxBE;AA0DXM,EAAAA,OAAO,EAAE;AACLhB,IAAAA,IADK,gBACAD,KADA,EACO;AACR,aAAOA,KAAK,CAACC,IAAb;AACH,KAHI;AAILC,IAAAA,QAJK,oBAIIF,KAJJ,EAIW;AACZ,aAAOA,KAAK,CAACE,QAAb;AACH,KANI;AAOLgB,IAAAA,GAAG,EAAE,aAAClB,KAAD;AAAA,aAAW,UAACmB,EAAD,EAAQ;AACpB,eAAOnB,KAAK,CAACC,IAAN,CAAWmB,IAAX,CAAgB,UAAAC,IAAI;AAAA,iBAAIA,IAAI,CAACF,EAAL,KAAYA,EAAhB;AAAA,SAApB,CAAP;AACH,OAFI;AAAA,KAPA;AAULhB,IAAAA,GAVK,eAUDH,KAVC,EAUM;AACP,aAAOA,KAAK,CAACG,GAAb;AACH;AAZI;AA1DE,CAAf","sourcesContent":["// 导入mutations命名常量\r\nimport {DELETE_ALL, SET_ITEM} from '@/store/modules/mutation-types';\r\nimport {getNoticeList,getNoticeListByPage,getNoticeDoc} from \"@/api/common\";\r\n\r\nexport default {\r\n    namespaced: true,\r\n    state: {\r\n        list: [],\r\n        homeList: [],\r\n        doc: {},\r\n    },\r\n    mutations: { // 同步操作方法\r\n        [SET_ITEM](state, payload) {\r\n            // state.list = payload.list;\r\n            state.list = state.list.concat(payload.list);\r\n        },\r\n        [\"SET_HOME_LIST\"](state, payload) {\r\n            state.homeList = [...payload.list];\r\n        },\r\n        [\"SET_DOC\"](state, payload) {\r\n            // state.list = payload.list;\r\n\r\n            state.doc = {...payload.data};\r\n        },\r\n        [DELETE_ALL](state, payload) {\r\n            state.list = [];\r\n        },\r\n    },\r\n    actions: { // 异步操作，用于操作mutations里面的方法，如果mutations里面的方法操作量大最好写在actions里面\r\n        list(conText, payload) {\r\n            getNoticeList().then(res => {\r\n                // console.log(res.data.list);\r\n                if (res.code === 1000) {\r\n                    conText.commit(\"SET_HOME_LIST\", {list: res.data});\r\n                }\r\n                if (payload.success) {\r\n                    payload.success(res);\r\n                }\r\n            });\r\n        },\r\n        listPage(conText, payload) {\r\n            getNoticeListByPage(payload.formData).then(res => {\r\n                // console.log(res.data.list);\r\n                if (res.code === 1000) {\r\n                    conText.commit(SET_ITEM, {list: res.data.list || []});\r\n                }\r\n                if (payload.success) {\r\n                    payload.success(res);\r\n                }\r\n            });\r\n        },\r\n        doc(conText, payload) {\r\n            getNoticeDoc(payload.formData).then(res => {\r\n                if (res.code === 1000) {\r\n                    conText.commit(\"SET_DOC\", {data: res.data});\r\n                }\r\n                if (payload.success) {\r\n                    payload.success(res);\r\n                }\r\n            });\r\n        }\r\n    },\r\n    getters: {\r\n        list(state) {\r\n            return state.list;\r\n        },\r\n        homeList(state) {\r\n            return state.homeList;\r\n        },\r\n        get: (state) => (id) => {\r\n            return state.list.find(item => item.id === id);\r\n        },\r\n        doc(state) {\r\n            return state.doc;\r\n        }\r\n    }\r\n}\r\n"]}]}