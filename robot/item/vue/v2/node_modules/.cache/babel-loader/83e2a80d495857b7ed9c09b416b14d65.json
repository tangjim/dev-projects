AAO,CAACM,QAAT,CAAV,CAA6BC,IAA7B,CAAkC,UAAAC,GAAG,EAAI;AACrC,YAAIA,GAAG,CAACC,IAAJ,KAAa,IAAjB,EAAuB;AACnBJ,UAAAA,OAAO,CAACK,MAAR,CAAe,SAAf,EAA0B;AAACR,YAAAA,IAAI,EAAEM,GAAG,CAACN;AAAX,WAA1B;AACH;;AACD,YAAIF,OAAO,CAACW,OAAZ,EAAqB;AACjBX,UAAAA,OAAO,CAACW,OAAR,CAAgBH,GAAhB;AACH;AACJ,OAPD;AAQH;AArBI,GAnBE;AA0CXI,EAAAA,OAAO,EAAE;AACLf,IAAAA,IADK,gBACAD,KADA,EACO;AACR,aAAOA,KAAK,CAACC,IAAb;AACH,KAHI;AAILC,IAAAA,GAJK,eAIDF,KAJC,EAIM;AACP,aAAOA,KAAK,CAACE,GAAb;AACH,KANI;AAOLe,IAAAA,GAAG,EAAE,aAACjB,KAAD;AAAA,aAAW,UAACkB,EAAD,EAAQ;AACpB,eAAOlB,KAAK,CAACC,IAAN,CAAWkB,IAAX,CAAgB,UAAAC,IAAI;AAAA,iBAAIA,IAAI,CAACF,EAAL,KAAYA,EAAhB;AAAA,SAApB,CAAP;AACH,OAFI;AAAA;AAPA;AA1CE,CAAf","sourcesContent":["// 导入mutations命名常量\r\nimport {DELETE_ALL, SET_ITEM} from '@/store/modules/mutation-types';\r\nimport {getHelpCenterList,getHelpDoc} from \"@/api/common\";\r\n\r\nexport default {\r\n    namespaced: true,\r\n    state: {\r\n        list: [],\r\n        doc: {},\r\n    },\r\n    mutations: { // 同步操作方法\r\n        [SET_ITEM](state, payload) {\r\n            // state.list = payload.list;\r\n            state.list = state.list.concat(payload.list);\r\n        },\r\n        [\"SET_DOC\"](state, payload) {\r\n            // state.list = payload.list;\r\n            state.doc = {...payload.data};\r\n        },\r\n        [DELETE_ALL](state, payload) {\r\n            state.list = [];\r\n        },\r\n    },\r\n    actions: { // 异步操作，用于操作mutations里面的方法，如果mutations里面的方法操作量大最好写在actions里面\r\n        listPage(conText, payload) {\r\n            getHelpCenterList(payload.formData).then(res => {\r\n                // console.log(res.data.list);\r\n                if (res.code === 1000) {\r\n                    conText.commit(SET_ITEM, {list: res.data.list || []});\r\n                }\r\n                if (payload.success) {\r\n                    payload.success(res);\r\n                }\r\n            });\r\n        },\r\n        doc(conText, payload) {\r\n            getHelpDoc(payload.formData).then(res => {\r\n                if (res.code === 1000) {\r\n                    conText.commit(\"SET_DOC\", {data: res.data});\r\n                }\r\n                if (payload.success) {\r\n                    payload.success(res);\r\n                }\r\n            });\r\n        }\r\n    },\r\n    getters: {\r\n        list(state) {\r\n            return state.list;\r\n        },\r\n        doc(state) {\r\n            return state.doc;\r\n        },\r\n        get: (state) => (id) => {\r\n            return state.list.find(item => item.id === id);\r\n        }\r\n    }\r\n}\r\n"]}]}