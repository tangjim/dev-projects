\r\n        }\r\n    },\r\n    actions: { // 异步操作，用于操作mutations里面的方法，如果mutations里面的方法操作量大最好写在actions里面\r\n        list(conText, payload) {\r\n            getRebateRankingList(payload.formData).then(res => {\r\n                if (res.code === 1000) {\r\n                    conText.commit(SET_ITEM, {list: res.data});\r\n                }\r\n                if (payload && payload.success) {\r\n                    payload.success(res);\r\n                }\r\n            });\r\n        }\r\n    },\r\n    getters: {\r\n        list(state) {\r\n            return state.list;\r\n        }\r\n    }\r\n}\r\n"]}]}